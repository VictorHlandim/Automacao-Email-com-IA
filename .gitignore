## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Artifacts
bin/
obj/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio cache/options directory
.vs/

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# Local environment
.env
.env.local

# OS specific
.DS_Store
Thumbs.db
